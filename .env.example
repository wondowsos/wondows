# Browser-visible Solana JSON-RPC (Helius, QuickNode, etc.)
# VITE_SOLANA_RPC_URL=

# Dev/preview only: Vite proxy adds this to Pinata requests. Never commit real tokens.
# PINATA_JWT=

# Optional: PumpDev API origin (default: /api/pumpdev in dev via Vite proxy incl. WSS /ws, https://pumpdev.io in prod).
# Avoid VITE_PUMPDEV_API_BASE=/ alone — it becomes empty and URLs break. Dev also proxies /api/create, /api/wallet, etc. to pumpdev.io.
# VITE_PUMPDEV_API_BASE=

# Optional overrides (defaults use same-origin /api/... paths)
# VITE_PINATA_UPLOAD_BASE=
